# --- MySQL ---
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DB=stock_god

# --- 钉钉股票监控机器人 ---
DINGTALK_STOCK_WEBHOOK=
DINGTALK_STOCK_SECRET=

# --- 钉钉 B站监控机器人 ---
DINGTALK_BILI_WEBHOOK=
DINGTALK_BILI_SECRET=

# --- DeepSeek ---
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com/v1
